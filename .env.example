# Copy to .env and fill in. Used by docker-compose.yml. (.env is gitignored.)

# Where the archive is written ON THE HOST. Create it yourself first (mkdir -p)
# so the files are owned by you. Use the big disk pool for the real runs:
#   ARCHIVE_DATA_DIR=/mnt/local-hddpool/<you>/atproto-archive
# For a quick test in your home dir you can leave the default (./data/archive).
ARCHIVE_DATA_DIR=./data/archive

# Your user/group ids, so output files aren't owned by root. Run: id -u / id -g
ARCHIVE_UID=1000
ARCHIVE_GID=1000

# Parallel repos fetched at once. Lower to 5 if the PDS starts rate-limiting.
CONCURRENCY=10
