# Copy to .env and fill in. Used by docker-compose.yml. (.env is gitignored.)

# Where the archive is written ON THE HOST. Create it yourself first (mkdir -p)
# so the files are owned by you. Use the big disk pool for the real runs:
#   ARCHIVE_DATA_DIR=/mnt/local-hddpool/<you>/atproto-archive
# For a quick test in your home dir you can leave the default (./data/archive).
ARCHIVE_DATA_DIR=./data/archive

# Your user/group ids, so output files aren't owned by root. Run: id -u / id -g
ARCHIVE_UID=1000
ARCHIVE_GID=1000

# Parallel repos fetched at once. The archiver also has a GLOBAL request throttle
# (~8.7 req/s) that keeps it under the PDS rate limit (eurosky.social: 3000 req /
# 300s) no matter how high this is, so 5 is plenty. Raising it won't speed things
# up much; the throttle is the real limiter.
CONCURRENCY=5

# Advanced: ms between request starts (global). 115 ≈ 8.7/s, safely under the
# 3000/300s limit. Lower slightly (e.g. 105) for a bit more speed, at a little
# more risk of brief 429s (which now back off automatically).
# MIN_REQUEST_INTERVAL_MS=115
